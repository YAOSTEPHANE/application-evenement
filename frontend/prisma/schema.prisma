generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  MANAGER
  COMMERCIAL
  STOREKEEPER
  TECHNICAL_MANAGER
  FLEET_MANAGER
  TECHNICIAN
  VIEWER
}

enum ItemStatus {
  AVAILABLE
  IN_REPAIR
  ARCHIVED
}

/// État physique / cycle de vie de l'article (affichage métier).
enum ItemCondition {
  NEW
  GOOD
  NEEDS_REPAIR
  OBSOLETE
}

enum MovementType {
  INBOUND
  OUTBOUND
  TRANSFER
  ADJUSTMENT
  LOSS
  /// Legacy — traité comme entrée (retour client)
  RETURN
}

enum MovementReason {
  PURCHASE
  CUSTOMER_RETURN
  MANUFACTURING
  SALE
  RENTAL
  EVENT
  INTERNAL_TRANSFER
  PHYSICAL_INVENTORY
  DAMAGE
  OTHER
}

enum ReturnCondition {
  OK
  DAMAGED
  MISSING
}

enum EventLifecycle {
  PLANNED
  PREPARING
  READY
  COMPLETED
  CANCELLED
}

enum WarehouseKind {
  WAREHOUSE
  STORE
  EVENT_SITE
}

/// Cycle commande CDC : Non traitée → Traitée → Soldée
enum OrderStatus {
  PENDING
  IN_PROGRESS
  SETTLED
}

enum RfidTagType {
  ON_METAL
  NAILED_WOOD
  TEXTILE
  ADHESIVE
  BOX_STANDARD
}

enum TrackedAssetStatus {
  AVAILABLE
  IN_TRANSIT
  ON_SITE
  QUARANTINE
  SCRAPPED
}

enum StockDocumentKind {
  BE
  BS
  BT
}

enum BeSubtype {
  BE_FRN
  BE_RET
  BE_TRF
  BE_REP
}

enum BsSubtype {
  BS_EVT
  BS_LOC
  BS_REP
  BS_RBT
}

enum BtSubtype {
  BT_EE
  BT_ES
  BT_SS
  BT_SE
}

enum StockDocumentStatus {
  DRAFT
  SCANNING
  PENDING_SIGNATURE
  SIGNED
  CANCELLED
  DISPUTED
}

enum BtTransitPhase {
  DEPARTURE
  IN_TRANSIT
  ARRIVAL
}

enum ResponsibilityPhase {
  STOCK
  TRANSPORT
  SITE
  DEMOUNT
  RETURN_STOCK
}

enum NotificationChannel {
  IN_APP
  EMAIL
  WHATSAPP
}

enum NotificationSeverity {
  INFO
  WARNING
  URGENT
  SUCCESS
}

enum ScanSource {
  PORTAL
  HANDHELD
}

/// Sens du passage contrôlé par un portique fixe (entrée / sortie de site).
enum PortalPassageDirection {
  EXIT
  ENTRY
  BOTH
}

/// Emplacement d'installation du portique (CDC §5.3.1).
enum PortalInstallationSite {
  WAREHOUSE_GATE
  LOADING_DOCK
}

enum StaffCategory {
  TEAM_LEADER
  RIGGER_JUNIOR
  RIGGER_CONFIRMED
  RIGGER_SENIOR
  DRIVER
  DAY_LABORER
}

enum StaffSpecialty {
  COLD
  ELECTRICAL
  DECORATION
  STAND
  CARPENTRY
}

enum VehicleStatus {
  AVAILABLE
  IN_USE
  MAINTENANCE
}

enum StorageZoneType {
  RECEPTION
  PICKING
  SHELVING
  RETURN
}

enum StorageZoneAccess {
  FREE
  RESTRICTED
}

enum ShelvingLevel {
  AISLE
  RACK
  SHELF
  BIN
}

enum ShelvingMaterial {
  METAL
  WOOD
  PLASTIC
}

enum StorageLocationFillState {
  EMPTY
  PARTIAL
  FULL
}

model Organization {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  /// Préférences organisation (entrepôt par défaut, cible inventaire, etc.)
  settings  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users        User[]
  categories   Category[]
  items        Item[]
  itemVariants ItemVariant[]
  events       Event[]
  warehouses   Warehouse[]
  storageZones StorageZone[]
  shelvingNodes ShelvingNode[]
  storageLocations StorageLocation[]
  locationStockBalances LocationStockBalance[]
  movements             StockMovement[]
  audits                AuditLog[]
  trackedAssets         TrackedAsset[]
  tagCodeSequences      TagCodeSequence[]
  stockDocuments        StockDocument[]
  vehicles              Vehicle[]
  staffProfiles         StaffProfile[]
  projectAssignments    ProjectAssignment[]
  dailyWorkerEntries    DailyWorkerEntry[]
  notifications         Notification[]
  responsibilityLogs  ResponsibilityLog[]
  documentSequences     DocumentSequence[]
  documentArchives      DocumentArchive[]
  rfidPortals           RfidPortal[]
  rfidHandhelds         RfidHandheld[]
}

model User {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  /** Identifiant de connexion (sans @), unique par organisation. L’e-mail reste utilisable seul si absent. */
  username       String?
  email          String   @unique
  fullName       String
  avatarUrl      String?
  passwordHash   String?
  role             Role
  active           Boolean  @default(true)
  twoFactorEnabled Boolean  @default(false)
  totpSecret       String?
  organizationId   String   @db.ObjectId
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  eventsOwned            Event[]              @relation("EventOwner")
  eventsAsCommercial     Event[]              @relation("EventCommercial")
  eventsAsTeamLeader     Event[]              @relation("EventTeamLeader")
  movements              StockMovement[]
  audits                 AuditLog[]
  staffProfile           StaffProfile?
  projectAssignments     ProjectAssignment[]
  documentSignatures     DocumentSignature[]
  custodyAssets          TrackedAsset[]       @relation("AssetCustodian")
  notifications          Notification[]
  rfidHandheldsAssigned  RfidHandheld[]       @relation("HandheldAssignee")
  responsibilityHolds    ResponsibilityLog[]  @relation("ResponsibilityHolder")
  vehicleAsDriver        Vehicle?             @relation("VehicleDriver")
  documentsAsShipper     StockDocument[]      @relation("DocShipper")
  documentsAsReceiver    StockDocument[]      @relation("DocReceiver")
  documentsAsDriver      StockDocument[]      @relation("DocDriver")

  @@index([organizationId])
  @@index([organizationId, username])
}

model Category {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  name           String
  slug           String
  /// Code standardisé unique (ex. MOB, MOB-CHR, MOB-CHR-NAP)
  code           String
  /// Verrouillé après codification RFID (segment TAG-XXXX immuable)
  codeLockedAt   DateTime?
  description    String?
  photoUrl       String?
  icon           String?
  metadata       Json?
  active         Boolean  @default(true)
  /// 0 = racine, 1 = enfant, 2 = sous-enfant
  level          Int      @default(0)
  parentId       String?  @db.ObjectId
  organizationId String   @db.ObjectId
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  parent       Category?    @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  children     Category[]   @relation("CategoryHierarchy")
  items        Item[]

  @@unique([organizationId, slug])
  @@unique([organizationId, code])
  @@index([organizationId])
  @@index([organizationId, parentId])
  @@index([organizationId, active])
}

model Item {
  id               String         @id @default(auto()) @map("_id") @db.ObjectId
  name             String
  reference        String
  description      String?
  photoUrl         String?
  galleryUrls      String[]       @default([])
  emoji            String?        @default("📦")
  notes            String?
  brand            String?
  model            String?
  variant          String?
  weightKg         Float?
  lengthCm         Float?
  widthCm          Float?
  heightCm         Float?
  barcode          String?
  /// Type de tag RFID recommandé pour cette famille d'articles
  defaultRfidTagType RfidTagType?
  serialNumber     String?
  lotNumber        String?
  supplierName     String?
  unitValue        Float
  rentalPrice      Float?
  salePrice        Float?
  usefulLifeMonths Int?
  totalQuantity    Int
  availableQty     Int
  allocatedQty     Int
  repairQty        Int
  minThreshold         Int            @default(0)
  maxStockQty          Int            @default(0)
  safetyStockQty       Int            @default(0)
  optimalStockQty      Int            @default(0)
  alertThresholdQty    Int            @default(0)
  criticalThresholdQty Int            @default(0)
  status               ItemStatus     @default(AVAILABLE)
  condition        ItemCondition  @default(GOOD)
  hasVariants      Boolean        @default(false)
  /// Champs métier libres (clé: valeur), selon l'industrie
  customFields       Json?
  technicalParams    String?
  certifications     String[]       @default([])
  safetyStandards    String[]       @default([])
  specialInstructions String?
  organizationId   String         @db.ObjectId
  categoryId       String         @db.ObjectId
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  organization Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  category     Category       @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  variants     ItemVariant[]
  eventItems   EventItem[]
  movements             StockMovement[]
  locationStockBalances LocationStockBalance[]
  trackedAssets         TrackedAsset[]

  @@unique([organizationId, reference])
  @@index([organizationId, name])
  @@index([organizationId, minThreshold])
  @@index([organizationId, barcode])
  @@index([organizationId, condition])
}

model Warehouse {
  id                String         @id @default(auto()) @map("_id") @db.ObjectId
  name              String
  /// Code unique par organisation (ex. WH-ABJ-01)
  code              String
  kind              WarehouseKind  @default(WAREHOUSE)
  address           String?
  city              String?
  latitude          Float?
  longitude         Float?
  totalCapacity     Int?
  capacityUnit      String?
  managerName       String?
  managerPhone      String?
  managerEmail      String?
  accessHours       String?
  specialConditions String[]       @default([])
  notes             String?
  active            Boolean        @default(true)
  organizationId    String         @db.ObjectId
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  organization     Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  storageZones     StorageZone[]
  storageLocations      StorageLocation[]
  locationStockBalances LocationStockBalance[]
  stockDocumentsFrom    StockDocument[] @relation("DocFromWarehouse")
  stockDocumentsTo      StockDocument[] @relation("DocToWarehouse")
  trackedAssets         TrackedAsset[]
  eventsAsSite          Event[]         @relation("EventSite")
  rfidPortals           RfidPortal[]
  rfidHandhelds         RfidHandheld[]

  @@unique([organizationId, code])
  @@index([organizationId, active])
  @@index([organizationId, name])
}

/// Lecteur RFID fixe (portique) aux passages entrée/sortie d'un site / entrepôt.
model RfidPortal {
  id               String                 @id @default(auto()) @map("_id") @db.ObjectId
  /// Identifiant matériel (ex. PORTIQUE-ABJ-NORD), unique par organisation
  code             String
  label            String
  locationHint       String?
  installationSite   PortalInstallationSite @default(WAREHOUSE_GATE)
  passageDirection   PortalPassageDirection @default(EXIT)
  active             Boolean                @default(true)
  lastScanAt       DateTime?
  warehouseId      String                 @db.ObjectId
  organizationId   String                 @db.ObjectId
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt

  organization Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  warehouse    Warehouse       @relation(fields: [warehouseId], references: [id], onDelete: Restrict)
  scanBatches  RfidScanBatch[]

  @@unique([organizationId, code])
  @@index([organizationId, active])
  @@index([warehouseId])
}

/// Lecteur RFID portatif (douchette) — inventaire et scan sur bon ouvert.
model RfidHandheld {
  id               String    @id @default(auto()) @map("_id") @db.ObjectId
  code             String
  label            String
  serialNumber         String?
  /// Autonomie cible (heures) — CDC : minimum une journée
  batteryAutonomyHours Int       @default(24)
  lastSyncAt           DateTime?
  active               Boolean   @default(true)
  lastScanAt           DateTime?
  warehouseId      String?   @db.ObjectId
  assignedUserId   String?   @db.ObjectId
  organizationId   String    @db.ObjectId
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  warehouse      Warehouse?     @relation(fields: [warehouseId], references: [id], onDelete: SetNull)
  assignedUser   User?          @relation("HandheldAssignee", fields: [assignedUserId], references: [id], onDelete: SetNull)
  scanBatches    RfidScanBatch[]

  @@unique([organizationId, code])
  @@index([organizationId, active])
  @@index([assignedUserId])
}

model StorageZone {
  id             String             @id @default(auto()) @map("_id") @db.ObjectId
  warehouseId    String             @db.ObjectId
  organizationId String             @db.ObjectId
  name           String
  /// Code unique au sein de l'entrepôt (ex. Z-RCP-A01)
  code           String
  zoneType       StorageZoneType
  /// Emplacement dans l'entrepôt (allée, rack, niveau…)
  locationLabel  String?
  totalCapacity  Int?
  capacityUnit   String?
  accessType     StorageZoneAccess  @default(FREE)
  notes          String?
  active         Boolean            @default(true)
  sortOrder      Int                @default(0)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  warehouse     Warehouse      @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  organization  Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  shelvingNodes    ShelvingNode[]
  storageLocations      StorageLocation[]
  locationStockBalances LocationStockBalance[]

  @@unique([warehouseId, code])
  @@index([organizationId, warehouseId])
  @@index([warehouseId, zoneType])
}

/// Hiérarchie rayonnage : Allée → Rack → Étagère → Emplacement (coordonnée A-1-2-3)
model ShelvingNode {
  id               String            @id @default(auto()) @map("_id") @db.ObjectId
  storageZoneId    String            @db.ObjectId
  organizationId   String            @db.ObjectId
  parentId         String?           @db.ObjectId
  level            ShelvingLevel
  /// Segment du code (A, 1, 2, 3) — coordonnée complète dans `coordinate`
  code             String
  label            String?
  /// Ex. A, A-1, A-1-2, A-1-2-3
  coordinate       String
  /// Type de structure (niveau Rack)
  materialType     ShelvingMaterial?
  /// Capacité de poids (niveau Emplacement)
  weightCapacityKg Float?
  widthCm          Float?
  heightCm         Float?
  depthCm          Float?
  notes            String?
  active           Boolean           @default(true)
  sortOrder        Int               @default(0)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  storageZone  StorageZone    @relation(fields: [storageZoneId], references: [id], onDelete: Cascade)
  organization Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  parent          ShelvingNode?     @relation("ShelvingHierarchy", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  children        ShelvingNode[]    @relation("ShelvingHierarchy")
  storageLocation StorageLocation?

  @@unique([storageZoneId, coordinate])
  @@index([organizationId, storageZoneId])
  @@index([storageZoneId, parentId])
  @@index([storageZoneId, level])
}

/// Emplacement individuel (slot opérationnel : capacité, état, GPS, conditions)
model StorageLocation {
  id                   String                   @id @default(auto()) @map("_id") @db.ObjectId
  warehouseId          String                   @db.ObjectId
  storageZoneId        String                   @db.ObjectId
  organizationId       String                   @db.ObjectId
  shelvingNodeId       String?                  @db.ObjectId
  code                 String
  label                String?
  hierarchyCoordinate  String?
  latitude             Float?
  longitude            Float?
  maxWeightKg          Float?
  maxVolumeM3          Float?
  maxItemCount         Int?
  fillState            StorageLocationFillState @default(EMPTY)
  minTempC             Float?
  maxTempC             Float?
  humidityPercent      Float?
  accessHeightCm       Float?
  accessWidthCm        Float?
  specialConditions    String[]                 @default([])
  notes                String?
  active               Boolean                  @default(true)
  sortOrder            Int                      @default(0)
  createdAt            DateTime                 @default(now())
  updatedAt            DateTime                 @updatedAt

  warehouse    Warehouse     @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  storageZone  StorageZone   @relation(fields: [storageZoneId], references: [id], onDelete: Cascade)
  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  shelvingNode          ShelvingNode?           @relation(fields: [shelvingNodeId], references: [id], onDelete: SetNull)
  locationStockBalances LocationStockBalance[]

  @@unique([organizationId, code])
  @@unique([shelvingNodeId])
  @@index([storageZoneId])
  @@index([warehouseId, storageZoneId])
}

/// Stock réparti par emplacement (physique / système, dispo / réservé / transit)
model LocationStockBalance {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  organizationId    String   @db.ObjectId
  itemId            String   @db.ObjectId
  itemVariantId     String?  @db.ObjectId
  warehouseId       String   @db.ObjectId
  storageZoneId     String   @db.ObjectId
  storageLocationId String   @db.ObjectId
  physicalQty       Int      @default(0)
  systemQty         Int      @default(0)
  availableQty      Int      @default(0)
  reservedQty       Int      @default(0)
  inTransitQty      Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  organization    Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  item            Item            @relation(fields: [itemId], references: [id], onDelete: Cascade)
  itemVariant     ItemVariant?    @relation(fields: [itemVariantId], references: [id], onDelete: Cascade)
  warehouse       Warehouse       @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  storageZone     StorageZone     @relation(fields: [storageZoneId], references: [id], onDelete: Cascade)
  storageLocation StorageLocation @relation(fields: [storageLocationId], references: [id], onDelete: Cascade)

  @@unique([storageLocationId, itemId, itemVariantId])
  @@index([organizationId, itemId])
  @@index([organizationId, warehouseId])
  @@index([organizationId, storageZoneId])
}

model Event {
  id             String         @id @default(auto()) @map("_id") @db.ObjectId
  name           String
  location       String
  clientName     String
  startsAt       DateTime
  endsAt         DateTime
  lifecycle      EventLifecycle @default(PLANNED)
  /// Statut commande CDC (Non traitée / Traitée / Soldée)
  orderStatus    OrderStatus    @default(PENDING)
  /// Validation trio opérationnel (CDC §6.1 — avant chargement BS-EVT)
  stockValidatedAt           DateTime?
  stockValidatedByUserId     String?   @db.ObjectId
  technicalValidatedAt       DateTime?
  technicalValidatedByUserId String?   @db.ObjectId
  fleetValidatedAt           DateTime?
  fleetValidatedByUserId     String?   @db.ObjectId
  notes          String?
  organizationId String         @db.ObjectId
  ownerId        String         @db.ObjectId
  commercialId   String?        @db.ObjectId
  teamLeaderId   String?        @db.ObjectId
  vehicleId      String?        @db.ObjectId
  eventSiteWarehouseId String?  @db.ObjectId
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  organization Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  owner        User           @relation("EventOwner", fields: [ownerId], references: [id], onDelete: Restrict)
  commercial   User?          @relation("EventCommercial", fields: [commercialId], references: [id], onDelete: SetNull)
  teamLeader   User?          @relation("EventTeamLeader", fields: [teamLeaderId], references: [id], onDelete: SetNull)
  vehicle      Vehicle?       @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  eventSite    Warehouse?     @relation("EventSite", fields: [eventSiteWarehouseId], references: [id], onDelete: SetNull)
  eventItems           EventItem[]
  movements            StockMovement[]
  stockDocuments       StockDocument[]
  projectAssignments   ProjectAssignment[]
  responsibilityLogs   ResponsibilityLog[]
  dailyWorkerEntries   DailyWorkerEntry[]

  @@index([organizationId, startsAt, endsAt])
  @@index([organizationId, orderStatus])
}

model ItemVariant {
  id               String         @id @default(auto()) @map("_id") @db.ObjectId
  itemId           String         @db.ObjectId
  reference        String
  label            String?
  size             String?
  color            String?
  modelName        String?
  unitValue        Float
  rentalPrice      Float?
  salePrice        Float?
  totalQuantity    Int
  availableQty     Int
  allocatedQty     Int
  repairQty        Int            @default(0)
  minThreshold         Int            @default(0)
  maxStockQty          Int            @default(0)
  safetyStockQty       Int            @default(0)
  optimalStockQty      Int            @default(0)
  alertThresholdQty    Int            @default(0)
  criticalThresholdQty Int            @default(0)
  condition            ItemCondition  @default(GOOD)
  status               ItemStatus     @default(AVAILABLE)
  barcode              String?
  photoUrl             String?
  sortOrder            Int            @default(0)
  organizationId       String         @db.ObjectId
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt

  organization Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  item         Item           @relation(fields: [itemId], references: [id], onDelete: Cascade)
  eventItems            EventItem[]
  movements             StockMovement[]
  locationStockBalances LocationStockBalance[]
  trackedAssets         TrackedAsset[]

  @@unique([organizationId, reference])
  @@index([itemId])
  @@index([organizationId, itemId])
}

model EventItem {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  eventId       String   @db.ObjectId
  itemId        String   @db.ObjectId
  itemVariantId String?  @db.ObjectId
  quantity      Int
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  event       Event        @relation(fields: [eventId], references: [id], onDelete: Cascade)
  item        Item         @relation(fields: [itemId], references: [id], onDelete: Restrict)
  itemVariant ItemVariant? @relation(fields: [itemVariantId], references: [id], onDelete: Restrict)

  @@unique([eventId, itemId, itemVariantId])
  @@index([itemId])
  @@index([itemVariantId])
}

model StockMovement {
  id              String          @id @default(auto()) @map("_id") @db.ObjectId
  movementType    MovementType
  movementReason  MovementReason?
  quantity        Int
  returnCondition ReturnCondition?
  notes           String?
  organizationId  String          @db.ObjectId
  itemId          String          @db.ObjectId
  itemVariantId   String?         @db.ObjectId
  eventId             String?         @db.ObjectId
  fromWarehouseId       String?         @db.ObjectId
  fromStorageZoneId     String?         @db.ObjectId
  fromStorageLocationId String?         @db.ObjectId
  toWarehouseId         String?         @db.ObjectId
  toStorageZoneId       String?         @db.ObjectId
  toStorageLocationId   String?         @db.ObjectId
  warehouseId           String?         @db.ObjectId
  storageZoneId         String?         @db.ObjectId
  storageLocationId     String?         @db.ObjectId
  countedQty            Int?
  actorId               String          @db.ObjectId
  createdAt             DateTime        @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  item         Item         @relation(fields: [itemId], references: [id], onDelete: Restrict)
  itemVariant  ItemVariant? @relation(fields: [itemVariantId], references: [id], onDelete: Restrict)
  event            Event?          @relation(fields: [eventId], references: [id], onDelete: SetNull)
  actor            User            @relation(fields: [actorId], references: [id], onDelete: Restrict)
  stockDocumentId  String?         @db.ObjectId
  stockDocument    StockDocument?  @relation(fields: [stockDocumentId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt])
  @@index([organizationId, movementType])
  @@index([itemId, createdAt])
  @@index([itemVariantId, createdAt])
  @@index([eventId])
  @@index([stockDocumentId])
}

/// Unité physique taguée RFID (suivi unitaire CDC)
model TrackedAsset {
  id                 String             @id @default(auto()) @map("_id") @db.ObjectId
  organizationId     String             @db.ObjectId
  tagCode            String
  /// Codification validée : le tagCode ne peut plus être modifié
  tagCodeValidatedAt       DateTime?
  tagCodeValidatedByUserId String?            @db.ObjectId
  itemId             String             @db.ObjectId
  itemVariantId      String?            @db.ObjectId
  rfidTagType        RfidTagType
  condition          ItemCondition      @default(GOOD)
  status             TrackedAssetStatus @default(AVAILABLE)
  photoUrl           String?
  notes              String?
  currentWarehouseId String?            @db.ObjectId
  currentEventId     String?            @db.ObjectId
  custodianUserId    String?            @db.ObjectId
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  organization     Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  item             Item              @relation(fields: [itemId], references: [id], onDelete: Restrict)
  itemVariant      ItemVariant?      @relation(fields: [itemVariantId], references: [id], onDelete: SetNull)
  currentWarehouse Warehouse?        @relation(fields: [currentWarehouseId], references: [id], onDelete: SetNull)
  custodian        User?             @relation("AssetCustodian", fields: [custodianUserId], references: [id], onDelete: SetNull)
  documentLines    DocumentLine[]
  responsibilityLogs ResponsibilityLog[]

  @@unique([organizationId, tagCode])
  @@index([organizationId, status])
  @@index([itemId])
  @@index([organizationId, tagCodeValidatedAt])
}

/// Séquence centralisée TAG-XXXX-YYYY par segment catégorie (XXXX)
model TagCodeSequence {
  id               String   @id @default(auto()) @map("_id") @db.ObjectId
  organizationId   String   @db.ObjectId
  categorySegment  String
  lastNumber       Int      @default(0)
  updatedAt        DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, categorySegment])
  @@index([organizationId])
}

/// Séquence numérotation BE/BS/BT (BE-2026-0001)
model DocumentSequence {
  id             String            @id @default(auto()) @map("_id") @db.ObjectId
  organizationId String            @db.ObjectId
  kind           StockDocumentKind
  year           Int
  lastNumber     Int               @default(0)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, kind, year])
}

/// Bon d'entrée / sortie / transfert (CDC)
model StockDocument {
  id                    String              @id @default(auto()) @map("_id") @db.ObjectId
  organizationId        String              @db.ObjectId
  kind                  StockDocumentKind
  beSubtype             BeSubtype?
  bsSubtype             BsSubtype?
  btSubtype             BtSubtype?
  documentNumber        String
  status                StockDocumentStatus @default(DRAFT)
  eventId               String?             @db.ObjectId
  sourceReference       String?
  fromWarehouseId       String?             @db.ObjectId
  toWarehouseId         String?             @db.ObjectId
  shipperUserId         String?             @db.ObjectId
  receiverUserId        String?             @db.ObjectId
  driverUserId          String?             @db.ObjectId
  notes                 String?
  anomalyNotes          String?
  photoUrls             String[]            @default([])
  signedAt              DateTime?
  cancelledAt           DateTime?
  reversesDocumentId    String?             @db.ObjectId
  correctsDocumentId    String?             @db.ObjectId
  btTransitPhase        BtTransitPhase?
  btEmittedAt           DateTime?
  btReceptionScannedAt  DateTime?
  transferDisputeOpenedAt DateTime?
  transferDisputeDeadline DateTime?
  portalValidatedAt     DateTime?
  archivedAt            DateTime?
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt

  organization      Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  event             Event?              @relation(fields: [eventId], references: [id], onDelete: SetNull)
  fromWarehouse     Warehouse?          @relation("DocFromWarehouse", fields: [fromWarehouseId], references: [id], onDelete: SetNull)
  toWarehouse       Warehouse?          @relation("DocToWarehouse", fields: [toWarehouseId], references: [id], onDelete: SetNull)
  shipper           User?               @relation("DocShipper", fields: [shipperUserId], references: [id], onDelete: SetNull)
  receiver          User?               @relation("DocReceiver", fields: [receiverUserId], references: [id], onDelete: SetNull)
  driver            User?               @relation("DocDriver", fields: [driverUserId], references: [id], onDelete: SetNull)
  reversesDocument  StockDocument?      @relation("DocumentReversal", fields: [reversesDocumentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  reversedBy        StockDocument[]     @relation("DocumentReversal")
  correctsDocument  StockDocument?      @relation("DocumentCorrection", fields: [correctsDocumentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  rectificatoryOf   StockDocument[]     @relation("DocumentCorrection")
  archive            DocumentArchive?
  lines             DocumentLine[]
  signatures        DocumentSignature[]
  scanBatches       RfidScanBatch[]
  movements         StockMovement[]
  responsibilityLogs ResponsibilityLog[]

  @@unique([organizationId, documentNumber])
  @@index([organizationId, kind, status])
  @@index([eventId])
}

/// Archive légale bon signé (conservation 10 ans CDC)
model DocumentArchive {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  organizationId  String   @db.ObjectId
  stockDocumentId String   @unique @db.ObjectId
  contentHash     String
  htmlSnapshot    String
  retentionUntil  DateTime
  createdAt       DateTime @default(now())

  organization  Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  stockDocument StockDocument @relation(fields: [stockDocumentId], references: [id], onDelete: Cascade)

  @@index([organizationId, retentionUntil])
}

model DocumentLine {
  id               String           @id @default(auto()) @map("_id") @db.ObjectId
  stockDocumentId  String           @db.ObjectId
  trackedAssetId   String?          @db.ObjectId
  itemId           String           @db.ObjectId
  itemVariantId    String?          @db.ObjectId
  designation      String?
  expectedQty      Int              @default(1)
  receivedQty      Int              @default(0)
  scannedQty       Int              @default(0)
  lineCondition    ReturnCondition?
  photoUrls        String[]         @default([])

  stockDocument StockDocument @relation(fields: [stockDocumentId], references: [id], onDelete: Cascade)
  trackedAsset  TrackedAsset? @relation(fields: [trackedAssetId], references: [id], onDelete: SetNull)

  @@index([stockDocumentId])
}

model DocumentSignature {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  stockDocumentId String   @db.ObjectId
  userId          String   @db.ObjectId
  roleAtSign      Role
  signedAt        DateTime @default(now())
  signatureHash   String?

  stockDocument StockDocument @relation(fields: [stockDocumentId], references: [id], onDelete: Cascade)
  user          User          @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([stockDocumentId])
}

model RfidScanBatch {
  id              String     @id @default(auto()) @map("_id") @db.ObjectId
  stockDocumentId String     @db.ObjectId
  rfidPortalId    String?    @db.ObjectId
  rfidHandheldId  String?    @db.ObjectId
  source          ScanSource
  tagCodes        String[]   @default([])
  scannedAt       DateTime   @default(now())

  stockDocument StockDocument @relation(fields: [stockDocumentId], references: [id], onDelete: Cascade)
  rfidPortal    RfidPortal?   @relation(fields: [rfidPortalId], references: [id], onDelete: SetNull)
  rfidHandheld  RfidHandheld? @relation(fields: [rfidHandheldId], references: [id], onDelete: SetNull)

  @@index([stockDocumentId])
  @@index([rfidPortalId])
  @@index([rfidHandheldId])
}

model ResponsibilityLog {
  id               String              @id @default(auto()) @map("_id") @db.ObjectId
  organizationId   String              @db.ObjectId
  trackedAssetId   String?             @db.ObjectId
  eventId          String?             @db.ObjectId
  stockDocumentId  String?             @db.ObjectId
  phase            ResponsibilityPhase
  holderUserId     String              @db.ObjectId
  startedAt        DateTime            @default(now())
  endedAt          DateTime?

  organization  Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  trackedAsset  TrackedAsset?  @relation(fields: [trackedAssetId], references: [id], onDelete: SetNull)
  event         Event?         @relation(fields: [eventId], references: [id], onDelete: SetNull)
  stockDocument StockDocument? @relation(fields: [stockDocumentId], references: [id], onDelete: SetNull)
  holder        User           @relation("ResponsibilityHolder", fields: [holderUserId], references: [id], onDelete: Restrict)

  @@index([organizationId, eventId])
  @@index([trackedAssetId])
}

model Vehicle {
  id             String        @id @default(auto()) @map("_id") @db.ObjectId
  organizationId String        @db.ObjectId
  label          String
  plateNumber    String
  capacityNotes  String?
  status         VehicleStatus @default(AVAILABLE)
  active         Boolean       @default(true)
  /** Chauffeur rattaché (§9.1). */
  driverUserId   String?       @unique @db.ObjectId
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  driver       User?          @relation("VehicleDriver", fields: [driverUserId], references: [id], onDelete: SetNull)
  events       Event[]

  @@unique([organizationId, plateNumber])
  @@index([organizationId, driverUserId])
}

model StaffProfile {
  id             String          @id @default(auto()) @map("_id") @db.ObjectId
  organizationId String          @db.ObjectId
  userId         String          @unique @db.ObjectId
  category       StaffCategory
  specialties    StaffSpecialty[] @default([])
  unavailable    Boolean         @default(false)
  unavailableUntil DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([organizationId, category])
}

model ProjectAssignment {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  organizationId String   @db.ObjectId
  eventId        String   @db.ObjectId
  userId         String   @db.ObjectId
  isTeamLeader   Boolean  @default(false)
  assignedAt     DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  event        Event        @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@index([organizationId, userId])
}

model DailyWorkerEntry {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  organizationId String   @db.ObjectId
  workDate       DateTime
  fullName       String
  eventId        String?  @db.ObjectId
  notes          String?
  hoursWorked    Float    @default(8)
  dailyRate      Float    @default(0)
  accountCode    String?
  /** Présence quotidienne déclarée le matin (§9.1). */
  morningDeclaredAt DateTime?
  sentToPayroll  Boolean  @default(false)
  payrollSentAt  DateTime?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  event        Event?       @relation(fields: [eventId], references: [id], onDelete: SetNull)

  @@index([organizationId, workDate])
}

model Notification {
  id             String               @id @default(auto()) @map("_id") @db.ObjectId
  organizationId String               @db.ObjectId
  userId         String               @db.ObjectId
  channel        NotificationChannel  @default(IN_APP)
  severity       NotificationSeverity @default(INFO)
  module         String
  title          String
  body           String
  targetType     String?
  targetId       String?
  readAt         DateTime?
  treatedAt      DateTime?
  createdAt      DateTime             @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([organizationId, userId, readAt])
  @@index([organizationId, severity])
}

model AuditLog {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  action         String
  targetType     String
  targetId       String
  payload        String?
  organizationId String   @db.ObjectId
  actorId        String   @db.ObjectId
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  actor        User         @relation(fields: [actorId], references: [id], onDelete: Restrict)

  @@index([organizationId, createdAt])
}
