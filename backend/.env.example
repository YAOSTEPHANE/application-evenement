#
# Variables d'environnement du backend
# Copiez ce fichier vers .env puis adaptez les valeurs.
#
# PowerShell:
# Copy-Item .env.example .env
#

# Même base que le frontend (Prisma : frontend/prisma/schema.prisma)
# Exemple (ajoutez serverSelectionTimeoutMS si besoin pour échouer vite au lieu de bloquer) :
# mongodb+srv://<user>:<password>@<cluster>.mongodb.net/envent_db?retryWrites=true&w=majority&appName=envent_db&serverSelectionTimeoutMS=10000
# Sur Atlas : Network Access → autoriser votre IP (ou 0.0.0.0/0 en dev uniquement).
DATABASE_URL="mongodb+srv://username:password@cluster0.example.mongodb.net/envent_db?retryWrites=true&w=majority&appName=envent_db"

# Mêmes secrets que frontend (sessions JWT, seed, cron CDC)
# AUTH_JWT_SECRET="min-32-caracteres-aleatoires-en-production"
# Alias accepté sur Vercel si déjà configuré : NEXTAUTH_SECRET (même valeur)
# SEED_SECRET="secret-long-aleatoire"
# CDC_CRON_SECRET="secret-cron-aleatoire"
# ALLOW_LEGACY_API_HEADERS="false"

# Origines autorisées pour le frontend (CORS). Obligatoire si le front n’est pas sur le même domaine.
# Local : http://localhost:3000
# Vercel : https://ton-projet-frontend.vercel.app (plusieurs URL séparées par des virgules)
# CORS_ALLOWED_ORIGINS="https://app.vercel.app"

# Optionnel en local
NODE_ENV="development"
