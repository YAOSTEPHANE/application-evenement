generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  MANAGER
  STOREKEEPER
  VIEWER
}

enum ItemStatus {
  AVAILABLE
  IN_REPAIR
  ARCHIVED
}

enum MovementType {
  OUTBOUND
  RETURN
  ADJUSTMENT
}

enum ReturnCondition {
  OK
  DAMAGED
  MISSING
}

model Organization {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users      User[]
  categories Category[]
  items      Item[]
  events     Event[]
  movements  StockMovement[]
  audits     AuditLog[]
}

model User {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  email          String   @unique
  fullName       String
  avatarUrl      String?
  passwordHash   String?
  role           Role
  organizationId String   @db.ObjectId
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  eventsOwned   Event[]       @relation("EventOwner")
  movements     StockMovement[]
  audits        AuditLog[]

  @@index([organizationId])
}

model Category {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  name           String
  slug           String
  organizationId String   @db.ObjectId
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  items        Item[]

  @@unique([organizationId, slug])
  @@index([organizationId])
}

model Item {
  id               String     @id @default(auto()) @map("_id") @db.ObjectId
  name             String
  reference        String
  photoUrl         String?
  unitValue        Float
  totalQuantity    Int
  availableQty     Int
  allocatedQty     Int
  repairQty        Int
  minThreshold     Int        @default(0)
  status           ItemStatus @default(AVAILABLE)
  organizationId   String     @db.ObjectId
  categoryId       String     @db.ObjectId
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  organization Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  category     Category       @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  eventItems   EventItem[]
  movements    StockMovement[]

  @@unique([organizationId, reference])
  @@index([organizationId, name])
  @@index([organizationId, minThreshold])
}

model Event {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  name           String
  location       String
  clientName     String
  startsAt       DateTime
  endsAt         DateTime
  organizationId String   @db.ObjectId
  ownerId        String   @db.ObjectId
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  owner        User           @relation("EventOwner", fields: [ownerId], references: [id], onDelete: Restrict)
  eventItems    EventItem[]
  movements     StockMovement[]

  @@index([organizationId, startsAt, endsAt])
}

model EventItem {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  eventId   String   @db.ObjectId
  itemId    String   @db.ObjectId
  quantity  Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  item  Item  @relation(fields: [itemId], references: [id], onDelete: Restrict)

  @@unique([eventId, itemId])
  @@index([itemId])
}

model StockMovement {
  id              String          @id @default(auto()) @map("_id") @db.ObjectId
  movementType    MovementType
  quantity        Int
  returnCondition ReturnCondition?
  notes           String?
  organizationId  String          @db.ObjectId
  itemId          String          @db.ObjectId
  eventId         String?         @db.ObjectId
  actorId         String          @db.ObjectId
  createdAt       DateTime        @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  item         Item         @relation(fields: [itemId], references: [id], onDelete: Restrict)
  event        Event?       @relation(fields: [eventId], references: [id], onDelete: SetNull)
  actor        User         @relation(fields: [actorId], references: [id], onDelete: Restrict)

  @@index([organizationId, createdAt])
  @@index([itemId, createdAt])
  @@index([eventId])
}

model AuditLog {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  action         String
  targetType     String
  targetId       String
  payload        String?
  organizationId String   @db.ObjectId
  actorId        String   @db.ObjectId
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  actor        User         @relation(fields: [actorId], references: [id], onDelete: Restrict)

  @@index([organizationId, createdAt])
}
